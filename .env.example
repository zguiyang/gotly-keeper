# ===========================================
# Required Infrastructure Variables
# ===========================================
# DATABASE_URL and REDIS_URL are required server-only variables.
# Clients can only access NEXT_PUBLIC_* variables.

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5434/gotly_dev

# Redis
REDIS_URL=redis://localhost:6382

# ===========================================
# Drizzle Migrations
# ===========================================
# Generate migrations after schema changes:
#   pnpm db:generate
#
# Apply migrations to database:
#   pnpm db:migrate
#
# Open Drizzle Studio (browser-based database explorer):
#   pnpm db:studio
