{
  "name": "gotly-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm verify:db && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "verify:db": "node --import tsx scripts/verify-db.ts",
    "assets:backfill-embeddings": "node --require ./scripts/register-server-only-alias.cjs --import tsx scripts/backfill-asset-embeddings.ts",
    "assets:backfill-structured": "node --require ./scripts/register-server-only-alias.cjs --import tsx scripts/backfill-structured-assets.ts",
    "worker:start": "node --require ./scripts/register-server-only-alias.cjs --import tsx scripts/run-workers.ts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm verify:db && pnpm typecheck && pnpm test:unit",
    "test": "vitest --run",
    "test:unit": "vitest --run tests/unit",
    "test:integration": "vitest --run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.17",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/react": "^3.0.160",
    "@base-ui/react": "^1.3.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@lexical/code": "^0.43.0",
    "@lexical/history": "^0.43.0",
    "@lexical/link": "^0.43.0",
    "@lexical/list": "^0.43.0",
    "@lexical/markdown": "^0.43.0",
    "@lexical/react": "^0.43.0",
    "@lexical/rich-text": "^0.43.0",
    "@tanstack/react-form": "^1.28.6",
    "ahooks": "^3.9.7",
    "ai": "^6.0.158",
    "better-auth": "^1.6.2",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "lexical": "^0.43.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "mustache": "^4.2.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.4"
  }
}
